{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cutflow.dev/schemas/overlays.schema.json",
  "$comment": "src/types.ts の Overlays の射影。トップレベルの許可キーは src/stages/validate.ts の KNOWN 配列と一致させる(test/schema.test.ts がピン留め)。zooms/blurs/annotations の reasonId は src/lib/effectReasonIds.ts の EFFECT_REASON_IDS と同順・同値。省略可・描画非影響。",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "MaterialKeyframe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["at", "values"],
      "properties": {
        "at": { "type": "number" },
        "easing": { "$ref": "common.schema.json#/$defs/KeyframeEasing" },
        "values": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "w": { "type": "number", "exclusiveMinimum": 0 },
            "h": { "type": "number", "exclusiveMinimum": 0 },
            "opacity": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      }
    },
    "BlurKeyframe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["at", "values"],
      "properties": {
        "at": { "type": "number" },
        "easing": { "$ref": "common.schema.json#/$defs/KeyframeEasing" },
        "values": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "w": { "type": "number", "exclusiveMinimum": 0 },
            "h": { "type": "number", "exclusiveMinimum": 0 },
            "strength": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      }
    },
    "ArrowKeyframe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["at", "values"],
      "properties": {
        "at": { "type": "number" },
        "easing": { "$ref": "common.schema.json#/$defs/KeyframeEasing" },
        "values": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "fromX": { "type": "number" },
            "fromY": { "type": "number" },
            "toX": { "type": "number" },
            "toY": { "type": "number" },
            "widthPx": { "type": "number", "exclusiveMinimum": 0 },
            "headPx": { "type": "number", "exclusiveMinimum": 0 }
          }
        }
      }
    },
    "BoxKeyframe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["at", "values"],
      "properties": {
        "at": { "type": "number" },
        "easing": { "$ref": "common.schema.json#/$defs/KeyframeEasing" },
        "values": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "w": { "type": "number", "exclusiveMinimum": 0 },
            "h": { "type": "number", "exclusiveMinimum": 0 },
            "widthPx": { "type": "number", "exclusiveMinimum": 0 },
            "radiusPx": { "type": "number", "minimum": 0 }
          }
        }
      }
    },
    "SpotlightKeyframe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["at", "values"],
      "properties": {
        "at": { "type": "number" },
        "easing": { "$ref": "common.schema.json#/$defs/KeyframeEasing" },
        "values": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "w": { "type": "number", "exclusiveMinimum": 0 },
            "h": { "type": "number", "exclusiveMinimum": 0 },
            "dim": { "type": "number", "minimum": 0, "maximum": 1 },
            "featherPx": { "type": "number", "minimum": 0 },
            "radiusPx": { "type": "number", "minimum": 0 }
          }
        }
      }
    },
    "ArrowAnnotation": {
      "type": "object",
      "required": ["type", "start", "end", "from", "to"],
      "properties": {
        "reasonId": { "enum": ["tiny-target", "focus-shift", "secret-exposure", "attention-scatter", "already-legible", "concept-talk", "motion-carries"] },
        "type": { "const": "arrow" },
        "start": { "type": "number" },
        "end": { "type": "number" },
        "from": { "$ref": "common.schema.json#/$defs/CaptionPos" },
        "to": { "$ref": "common.schema.json#/$defs/CaptionPos" },
        "color": { "type": "string" },
        "widthPx": { "type": "number", "minimum": 0 },
        "headPx": { "type": "number", "minimum": 0 },
        "keyframes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "items": { "$ref": "#/$defs/ArrowKeyframe" }
        }
      }
    },
    "BoxAnnotation": {
      "type": "object",
      "required": ["type", "start", "end", "rect"],
      "properties": {
        "reasonId": { "enum": ["tiny-target", "focus-shift", "secret-exposure", "attention-scatter", "already-legible", "concept-talk", "motion-carries"] },
        "type": { "const": "box" },
        "start": { "type": "number" },
        "end": { "type": "number" },
        "rect": { "$ref": "common.schema.json#/$defs/Region" },
        "color": { "type": "string" },
        "widthPx": { "type": "number", "minimum": 0 },
        "radiusPx": { "type": "number", "minimum": 0 },
        "fill": { "type": "string" },
        "keyframes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "items": { "$ref": "#/$defs/BoxKeyframe" }
        }
      }
    },
    "SpotlightAnnotation": {
      "type": "object",
      "required": ["type", "start", "end", "rect"],
      "properties": {
        "reasonId": { "enum": ["tiny-target", "focus-shift", "secret-exposure", "attention-scatter", "already-legible", "concept-talk", "motion-carries"] },
        "type": { "const": "spotlight" },
        "start": { "type": "number" },
        "end": { "type": "number" },
        "rect": { "$ref": "common.schema.json#/$defs/Region" },
        "shape": { "enum": ["rect", "ellipse"] },
        "dim": { "type": "number", "minimum": 0, "maximum": 1 },
        "featherPx": { "type": "number", "minimum": 0 },
        "radiusPx": { "type": "number", "minimum": 0 },
        "keyframes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "items": { "$ref": "#/$defs/SpotlightKeyframe" }
        }
      }
    },
    "WipeFull": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "id": { "$ref": "common.schema.json#/$defs/id" },
        "start": { "type": "number", "minimum": 0 },
        "end": { "type": "number", "minimum": 0 },
        "transitionSec": {
          "type": "number",
          "minimum": 0,
          "description": "旧形式。transitionInSec / transitionOutSec が無い方向の遷移秒"
        },
        "transitionInSec": { "type": "number", "minimum": 0 },
        "transitionOutSec": { "type": "number", "minimum": 0 }
      }
    }
  },
  "properties": {
    "overlays": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["start", "end", "file"],
        "properties": {
          "id": { "$ref": "common.schema.json#/$defs/id" },
          "start": { "type": "number" },
          "end": { "type": "number" },
          "file": { "type": "string" },
          "track": { "type": "integer", "minimum": 1 },
          "layer": { "enum": ["under", "over"] },
          "fit": { "enum": ["contain", "cover"] },
          "startFrom": { "type": "number", "minimum": 0 },
          "volume": { "type": "number", "minimum": 0, "maximum": 2 },
          "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
          "fadeInSec": { "type": "number", "minimum": 0 },
          "fadeOutSec": { "type": "number", "minimum": 0 },
          "rect": { "$ref": "common.schema.json#/$defs/Region" },
          "keyframes": {
            "type": "array",
            "minItems": 1,
            "maxItems": 100,
            "items": { "$ref": "#/$defs/MaterialKeyframe" }
          }
        }
      }
    },
    "inserts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["at", "file", "durationSec"],
        "properties": {
          "id": { "$ref": "common.schema.json#/$defs/id" },
          "at": { "type": "number", "minimum": 0 },
          "file": { "type": "string" },
          "durationSec": { "type": "number" },
          "startFrom": { "type": "number", "minimum": 0 },
          "fit": { "enum": ["contain", "cover"] },
          "volume": { "type": "number", "minimum": 0, "maximum": 2 },
          "fadeInSec": { "type": "number", "minimum": 0 },
          "fadeOutSec": { "type": "number", "minimum": 0 }
        }
      }
    },
    "wipeFull": {
      "type": "array",
      "items": { "$ref": "#/$defs/WipeFull" }
    },
    "layerOrder": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(wipe|caption|ov[1-9][0-9]*|cap[1-9][0-9]*)$"
      }
    },
    "captionTracks": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/CaptionTrackDef" }
    },
    "hideCaption": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/Interval" }
    },
    "zooms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["start", "end", "rect"],
        "properties": {
          "id": { "$ref": "common.schema.json#/$defs/id" },
          "reasonId": { "enum": ["tiny-target", "focus-shift", "secret-exposure", "attention-scatter", "already-legible", "concept-talk", "motion-carries"] },
          "start": { "type": "number" },
          "end": { "type": "number" },
          "rect": { "$ref": "common.schema.json#/$defs/Region" },
          "easeSec": { "type": "number", "minimum": 0 },
          "easeOutSec": { "type": "number", "minimum": 0 }
        }
      }
    },
    "colorFilter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "brightness": { "type": "number", "minimum": 0, "maximum": 3 },
        "contrast": { "type": "number", "minimum": 0, "maximum": 3 },
        "saturate": { "type": "number", "minimum": 0, "maximum": 3 }
      }
    },
    "blurs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["start", "end", "rect"],
        "properties": {
          "id": { "$ref": "common.schema.json#/$defs/id" },
          "reasonId": { "enum": ["tiny-target", "focus-shift", "secret-exposure", "attention-scatter", "already-legible", "concept-talk", "motion-carries"] },
          "start": { "type": "number" },
          "end": { "type": "number" },
          "rect": { "$ref": "common.schema.json#/$defs/Region" },
          "strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "keyframes": {
            "type": "array",
            "minItems": 1,
            "maxItems": 100,
            "items": { "$ref": "#/$defs/BlurKeyframe" }
          }
        }
      }
    },
    "annotations": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/ArrowAnnotation" },
          { "$ref": "#/$defs/BoxAnnotation" },
          { "$ref": "#/$defs/SpotlightAnnotation" }
        ]
      }
    }
  }
}
