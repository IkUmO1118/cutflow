{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cutflow.dev/schemas/thumbnail.schema.json",
  "$comment": "src/types.ts の Thumbnail / ThumbnailText の射影。t は元収録の秒だが、frames と違いカット済みの瞬間へもスナップしない。style は transcript のテロップと同じ CaptionStyle を共有する。",
  "type": "object",
  "required": ["t", "texts"],
  "properties": {
    "t": { "type": "number", "minimum": 0 },
    "texts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["text", "pos"],
        "properties": {
          "id": { "$ref": "common.schema.json#/$defs/id" },
          "text": { "type": "string" },
          "pos": { "$ref": "common.schema.json#/$defs/CaptionPos" },
          "style": { "$ref": "common.schema.json#/$defs/CaptionStyle" }
        }
      }
    }
  }
}
