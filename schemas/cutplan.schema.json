{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cutflow.dev/schemas/cutplan.schema.json",
  "$comment": "src/types.ts の CutPlan / PlanSegment の射影。approved は人間の承認意図の表示に過ぎず、render の実ゲートは approvals.json(このスキーマの対象外。§AGENTS_CONTRACT.md 承認境界)。segments の時系列順・重なり禁止は node src/cli.ts validate が担う(schema はここでは検査しない)。reasonId の enum は src/lib/reasonIds.ts の CUT_REASON_IDS と同順・同値(test/schema.test.ts がピン留め)。省略可=未分類(opt-in・sticky)。",
  "type": "object",
  "required": ["approved", "segments"],
  "properties": {
    "approved": { "type": "boolean" },
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["start", "end", "action", "reason"],
        "properties": {
          "id": { "$ref": "common.schema.json#/$defs/id" },
          "start": { "type": "number" },
          "end": { "type": "number" },
          "action": { "enum": ["keep", "cut"] },
          "reason": { "type": "string" },
          "reasonId": {
            "enum": [
              "restatement",
              "stumble",
              "duplicate-tail",
              "gap-trim",
              "dead-air",
              "tangent",
              "slate",
              "demo-wait",
              "failure-and-fix",
              "hook",
              "greeting",
              "tail-clip",
              "reference-orphan"
            ]
          },
          "speed": { "type": "number", "minimum": 0.25, "maximum": 4 }
        }
      }
    }
  }
}
